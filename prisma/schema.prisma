// Peptides Tracker — Prisma schema
// NOTE: This schema kept SQLite-friendly shapes (String "enums", Json arrays)
// from its local-first origin; Postgres stores both natively so they carry over
// unchanged. Enum-like fields stay String (validated in app via zod, see
// src/types); arrays / structured blobs stay Json. src/types/peptide.ts remains
// the single source of truth for valid values + parsing.
//
// Datasource url lives in prisma.config.ts (Prisma 7 driver-adapter style):
// runtime uses the pooled DATABASE_URL (src/lib/db.ts, Neon adapter); migrate +
// seed use the direct (unpooled) connection via prisma.config.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Auth identity (one login). Owns one or more profiles (User). All
// profile-owned data stays scoped by userId; profiles are scoped to an Account.
model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles User[]
}

// A tracked person/profile (e.g. "Me", "Partner"). Belongs to an Account.
model User {
  id         String   @id @default(cuid())
  accountId  String?
  name       String   @default("Me")
  email      String?  @unique
  weightUnit String   @default("kg") // kg | lb
  doseUnit   String   @default("mcg") // mcg | mg
  theme      String   @default("system") // system | light | dark
  color      String? // hex accent for the profile switcher / calendar
  sex        String? // M | F | other — used for sex-aware biomarker reference ranges
  birthYear  Int? // used to derive age for age-aware reference ranges
  timezone   String? // IANA tz (e.g. "America/New_York") — reminders compute "today" in it
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account      Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cycles       Cycle[]
  stacks       Stack[]
  measurements Measurement[]
  journal      JournalEntry[]
  doseLogs     DoseLog[]
  vials        Vial[]
  stockItems   StockItem[]
  labs         LabResult[]
  photos       Photo[]
  pushSubscriptions PushSubscription[]
  supplements       Supplement[]
  supplementLogs    SupplementLog[]
  labReminders      LabReminder[]
  checkIns          CheckIn[]

  @@index([accountId])
}

// Daily wellbeing check-in: one row per profile per day. Ratings is a
// Record<markerKey, 1-5> — marker keys live in src/types/checkin.ts (Json,
// SQLite-origin style) so new markers never need a migration.
model CheckIn {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime // normalized to local midnight at entry
  ratings     Json // Record<string, number 1-5>
  sideEffects Json? // string[]
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// Web Push subscription for PWA dose reminders. One row per browser/device push
// endpoint, scoped to the profile that subscribed. iOS delivers web push only to
// a PWA installed to the home screen (iOS 16.4+).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String // client public key (subscription.keys.p256dh)
  auth      String // client auth secret (subscription.keys.auth)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Peptide {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  aliases           Json // string[]
  category          String // GLP_GIP | GH_SECRETAGOGUE | HEALING_REPAIR | MITOCHONDRIAL | COSMETIC | NOOTROPIC_ANXIOLYTIC | IMMUNE_ANTIINFLAMMATORY
  summary           String
  mechanism         String
  benefits          Json // string[]
  risks             Json // string[]
  sideEffects       Json // string[]
  dosage            Json // { low, standard, high, unit, notes, timing?, maxDose?, protocols?: [{ label?, steps: [{ weeks, amount, unit }] }] }
  route             String // SUBQ | IM | NASAL | TOPICAL | ORAL
  frequency         String
  halfLife          String
  halfLifeHours     Float? // numeric elimination half-life (hours) — drives the PK/active-levels chart
  cycleLength       String
  reconstitution    Json // { vialMg, bacWaterMl, notes }
  storage           String
  contraindications Json // string[]
  interactions      Json // { with, kind, note }[]  (raw, includes non-peptide entities)
  references        Json // { title, url }[]
  tags              Json // string[] goal tags
  status            String   @default("research")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stackItems    StackItem[]
  doseLogs      DoseLog[]
  cycles        Cycle[]
  vials         Vial[]
  stockItems    StockItem[]
  interactionsA PeptideInteraction[] @relation("InteractionA")
  interactionsB PeptideInteraction[] @relation("InteractionB")
}

// Peptide-to-peptide interactions only (powers combine/stack checks).
model PeptideInteraction {
  id         String  @id @default(cuid())
  peptideAId String
  peptideBId String
  kind       String // synergy | caution | avoid
  note       String
  peptideA   Peptide @relation("InteractionA", fields: [peptideAId], references: [id], onDelete: Cascade)
  peptideB   Peptide @relation("InteractionB", fields: [peptideBId], references: [id], onDelete: Cascade)

  @@unique([peptideAId, peptideBId])
}

model Stack {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  goal        String?
  description String
  isPreset    Boolean  @default(false)
  tags        Json? // string[]
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items  StackItem[]
  cycles Cycle[]
}

model StackItem {
  id        String  @id @default(cuid())
  stackId   String
  peptideId String
  dose      String?
  frequency String?
  timing    String?
  notes     String?
  order     Int     @default(0)
  stack     Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)
  peptide   Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)

  @@unique([stackId, peptideId])
}

model Cycle {
  id             String    @id @default(cuid())
  userId         String
  name           String
  peptideId      String?
  stackId        String?
  startDate      DateTime
  endDate        DateTime?
  status         String    @default("planned") // planned | active | paused | completed
  scheduleConfig Json? // { days, timesPerDay, dosePerAdmin, unit, ... }
  washoutDays    Int? // planned rest period after the cycle ends before re-running the compound
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  peptide  Peptide?  @relation(fields: [peptideId], references: [id], onDelete: SetNull)
  stack    Stack?    @relation(fields: [stackId], references: [id], onDelete: SetNull)
  doseLogs DoseLog[]
}

model DoseLog {
  id          String   @id @default(cuid())
  userId      String? // owning profile (nullable for legacy rows; always set on create)
  cycleId     String?
  peptideId   String
  vialId      String? // optional source vial (decrements its remaining on log)
  takenAt     DateTime @default(now())
  amount      Float
  unit        String   @default("mcg")
  route       String?
  site        String? // injection-site rotation label
  mood        Int? // 1-5 wellbeing rating
  energy      Int? // 1-5 energy rating
  sideEffects Json? // string[]
  notes       String?
  createdAt   DateTime @default(now()) // logged-at; tiebreaker for same-takenAt ordering
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle       Cycle?   @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  peptide     Peptide  @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  vial        Vial?    @relation(fields: [vialId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// Reconstituted/sealed peptide vials — inventory + expiry tracking.
model Vial {
  id                   String    @id @default(cuid())
  userId               String
  peptideId            String
  label                String?
  totalMcg             Float // total peptide in the vial (mcg)
  bacWaterMl           Float? // diluent volume when reconstituted
  concentrationMcgPerMl Float? // derived: totalMcg / bacWaterMl
  remainingMcg         Float // decremented as doses are drawn
  reconstitutedAt      DateTime?
  expiresAt            DateTime?
  status               String    @default("sealed") // sealed | active | empty | expired
  price                Float? // what this vial cost (user's currency) — drives cost-per-dose
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  peptide  Peptide   @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  doseLogs DoseLog[]

  @@index([userId])
}

// Stock reserve — unopened vials held per peptide (quantity-based), with a
// planned dose + frequency used to ESTIMATE remaining supply. Activating a stock
// item reconstitutes one vial into an active `Vial` (see actions/stock.ts).
model StockItem {
  id        String   @id @default(cuid())
  userId    String
  peptideId String
  vialMcg   Float // size of ONE vial (mcg); 5 mg → 5000
  quantity  Int      @default(1) // unopened vials in reserve
  dose      Float? // planned dose per administration (in doseUnit)
  doseUnit  String   @default("mcg") // mcg | mg
  frequency String   @default("daily") // Frequency (see src/lib/schedule.ts)
  price     Float? // price per vial (user's currency) — drives cost estimation
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  peptide Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Bloodwork / lab markers over time.
model LabResult {
  id            String   @id @default(cuid())
  userId        String
  marker        String // e.g. "IGF-1", "Free T", "HbA1c" (display label)
  biomarkerSlug String? // optional link to the global Biomarker catalog (KB + panel grouping)
  value         Float
  unit          String?
  refLow        Float? // reference range snapshotted at entry (stable flagging)
  refHigh       Float?
  takenAt       DateTime @default(now())
  cycleId       String?
  notes         String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Progress photos (stored in Vercel Blob; path is an absolute public Blob URL).
model Photo {
  id      String   @id @default(cuid())
  userId  String
  path    String // absolute Blob URL, e.g. https://<id>.public.blob.vercel-storage.com/<file>
  caption String?
  takenAt DateTime @default(now())
  tags    Json? // string[]
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Measurement {
  id         String   @id @default(cuid())
  userId     String
  type       String // weight | bodyFat | sleep | recovery | custom
  label      String?
  value      Float
  unit       String?
  recordedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id      String   @id @default(cuid())
  userId  String
  date    DateTime @default(now())
  body    String
  tags    Json? // string[]
  cycleId String?
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Global biomarker catalog + cited knowledge base (the labs analog of Peptide).
// Like Peptide, enum-like fields are String and arrays/objects are Json; the
// source of truth for valid values + parsing is src/types/biomarker.ts.
model Biomarker {
  id              String   @id @default(cuid())
  slug            String   @unique // e.g. "alt", "ldl-cholesterol", "creatinine"
  name            String // e.g. "ALT (alanine aminotransferase)"
  aliases         Json // string[]  e.g. ["GPT","SGPT"]
  system          String // LIPIDS | LIVER | RENAL | METABOLIC | HORMONE | THYROID | HEMATOLOGY | VITAMIN | INFLAMMATION | OTHER
  unit            String // default display unit, e.g. "U/L", "mg/dL", "ng/dL"
  summary         String
  whatItMeans     String
  raises          Json // string[]
  lowers          Json // string[]
  confounders     Json // string[]
  relatedPeptides Json // string[] peptide slugs
  ranges          Json // RefRange[]: { sex?, ageMin?, ageMax?, low?, high?, unit?, note? }
  references      Json // { title, url }[]
  direction       String? // "high" = higher is worse, "low" = lower is worse, null = context-dependent
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Continuous supplements (vitamins, minerals, omega-3, creatine, …). Tracked as
// date ranges — they overlay the biomarker timeline as confounder bands. No
// per-dose logging (these are taken continuously).
model Supplement {
  id          String    @id @default(cuid())
  userId      String
  name        String
  category    String? // vitamin | mineral | omega | amino | herbal | other
  dose        String? // free-form, e.g. "5 g", "2000 IU"
  frequency   String? // free-form, e.g. "daily"
  timesPerDay Int? // planned intakes/day — drives adherence math (null = untracked)
  timing      String? // free-form, e.g. "morning, with food"
  startDate   DateTime
  endDate     DateTime?
  status      String    @default("active") // active | paused | stopped
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  logs SupplementLog[]

  @@index([userId])
}

// One logged supplement intake (adherence). Distinct from the continuous
// date-range Supplement it belongs to.
model SupplementLog {
  id           String   @id @default(cuid())
  userId       String
  supplementId String
  takenAt      DateTime @default(now())
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplement Supplement @relation(fields: [supplementId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([supplementId])
}

// One-off lab-recheck action items (e.g. "Recheck ALT", "Cistatin C off creatine").
// Surfaced as a daily push via the existing reminders cron when dueAt <= now.
model LabReminder {
  id             String    @id @default(cuid())
  userId         String
  biomarkerSlug  String? // optional link to the catalog
  label          String // e.g. "Recheck ALT/AST"
  dueAt          DateTime
  note           String?
  completedAt    DateTime?
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
