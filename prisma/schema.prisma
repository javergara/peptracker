// Peptides Tracker — Prisma schema
// NOTE: This schema kept SQLite-friendly shapes (String "enums", Json arrays)
// from its local-first origin; Postgres stores both natively so they carry over
// unchanged. Enum-like fields stay String (validated in app via zod, see
// src/types); arrays / structured blobs stay Json. src/types/peptide.ts remains
// the single source of truth for valid values + parsing.
//
// Datasource url lives in prisma.config.ts (Prisma 7 driver-adapter style):
// runtime uses the pooled DATABASE_URL (src/lib/db.ts, Neon adapter); migrate +
// seed use the direct (unpooled) connection via prisma.config.ts.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Auth identity (one login). Owns one or more profiles (User). All
// profile-owned data stays scoped by userId; profiles are scoped to an Account.
model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profiles User[]
}

// A tracked person/profile (e.g. "Me", "Partner"). Belongs to an Account.
model User {
  id         String   @id @default(cuid())
  accountId  String?
  name       String   @default("Me")
  email      String?  @unique
  weightUnit String   @default("kg") // kg | lb
  doseUnit   String   @default("mcg") // mcg | mg
  theme      String   @default("system") // system | light | dark
  color      String? // hex accent for the profile switcher / calendar
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  account      Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cycles       Cycle[]
  stacks       Stack[]
  measurements Measurement[]
  journal      JournalEntry[]
  doseLogs     DoseLog[]
  vials        Vial[]
  labs         LabResult[]
  photos       Photo[]

  @@index([accountId])
}

model Peptide {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  aliases           Json // string[]
  category          String // GLP_GIP | GH_SECRETAGOGUE | HEALING_REPAIR | MITOCHONDRIAL | COSMETIC | NOOTROPIC_ANXIOLYTIC | IMMUNE_ANTIINFLAMMATORY
  summary           String
  mechanism         String
  benefits          Json // string[]
  risks             Json // string[]
  sideEffects       Json // string[]
  dosage            Json // { low, standard, high, unit, notes, timing?, maxDose?, protocols?: [{ label?, steps: [{ weeks, amount, unit }] }] }
  route             String // SUBQ | IM | NASAL | TOPICAL | ORAL
  frequency         String
  halfLife          String
  cycleLength       String
  reconstitution    Json // { vialMg, bacWaterMl, notes }
  storage           String
  contraindications Json // string[]
  interactions      Json // { with, kind, note }[]  (raw, includes non-peptide entities)
  references        Json // { title, url }[]
  tags              Json // string[] goal tags
  status            String   @default("research")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stackItems    StackItem[]
  doseLogs      DoseLog[]
  cycles        Cycle[]
  vials         Vial[]
  interactionsA PeptideInteraction[] @relation("InteractionA")
  interactionsB PeptideInteraction[] @relation("InteractionB")
}

// Peptide-to-peptide interactions only (powers combine/stack checks).
model PeptideInteraction {
  id         String  @id @default(cuid())
  peptideAId String
  peptideBId String
  kind       String // synergy | caution | avoid
  note       String
  peptideA   Peptide @relation("InteractionA", fields: [peptideAId], references: [id], onDelete: Cascade)
  peptideB   Peptide @relation("InteractionB", fields: [peptideBId], references: [id], onDelete: Cascade)

  @@unique([peptideAId, peptideBId])
}

model Stack {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  goal        String?
  description String
  isPreset    Boolean  @default(false)
  tags        Json? // string[]
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items  StackItem[]
  cycles Cycle[]
}

model StackItem {
  id        String  @id @default(cuid())
  stackId   String
  peptideId String
  dose      String?
  frequency String?
  timing    String?
  notes     String?
  order     Int     @default(0)
  stack     Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)
  peptide   Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)

  @@unique([stackId, peptideId])
}

model Cycle {
  id             String    @id @default(cuid())
  userId         String
  name           String
  peptideId      String?
  stackId        String?
  startDate      DateTime
  endDate        DateTime?
  status         String    @default("planned") // planned | active | paused | completed
  scheduleConfig Json? // { days, timesPerDay, dosePerAdmin, unit, ... }
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  peptide  Peptide?  @relation(fields: [peptideId], references: [id], onDelete: SetNull)
  stack    Stack?    @relation(fields: [stackId], references: [id], onDelete: SetNull)
  doseLogs DoseLog[]
}

model DoseLog {
  id          String   @id @default(cuid())
  userId      String? // owning profile (nullable for legacy rows; always set on create)
  cycleId     String?
  peptideId   String
  vialId      String? // optional source vial (decrements its remaining on log)
  takenAt     DateTime @default(now())
  amount      Float
  unit        String   @default("mcg")
  route       String?
  site        String? // injection-site rotation label
  mood        Int? // 1-5 wellbeing rating
  energy      Int? // 1-5 energy rating
  sideEffects Json? // string[]
  notes       String?
  createdAt   DateTime @default(now()) // logged-at; tiebreaker for same-takenAt ordering
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle       Cycle?   @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  peptide     Peptide  @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  vial        Vial?    @relation(fields: [vialId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// Reconstituted/sealed peptide vials — inventory + expiry tracking.
model Vial {
  id                   String    @id @default(cuid())
  userId               String
  peptideId            String
  label                String?
  totalMcg             Float // total peptide in the vial (mcg)
  bacWaterMl           Float? // diluent volume when reconstituted
  concentrationMcgPerMl Float? // derived: totalMcg / bacWaterMl
  remainingMcg         Float // decremented as doses are drawn
  reconstitutedAt      DateTime?
  expiresAt            DateTime?
  status               String    @default("sealed") // sealed | active | empty | expired
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  peptide  Peptide   @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  doseLogs DoseLog[]

  @@index([userId])
}

// Bloodwork / lab markers over time.
model LabResult {
  id      String   @id @default(cuid())
  userId  String
  marker  String // e.g. "IGF-1", "Free T", "HbA1c"
  value   Float
  unit    String?
  refLow  Float?
  refHigh Float?
  takenAt DateTime @default(now())
  cycleId String?
  notes   String?
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Progress photos (stored in Vercel Blob; path is an absolute public Blob URL).
model Photo {
  id      String   @id @default(cuid())
  userId  String
  path    String // absolute Blob URL, e.g. https://<id>.public.blob.vercel-storage.com/<file>
  caption String?
  takenAt DateTime @default(now())
  tags    Json? // string[]
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Measurement {
  id         String   @id @default(cuid())
  userId     String
  type       String // weight | bodyFat | sleep | recovery | custom
  label      String?
  value      Float
  unit       String?
  recordedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id      String   @id @default(cuid())
  userId  String
  date    DateTime @default(now())
  body    String
  tags    Json? // string[]
  cycleId String?
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
