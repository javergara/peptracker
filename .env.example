# Copy to .env (local) and set the same vars in your Vercel project (production).

# --- Database (Neon Postgres) ---
# Pooled connection (runtime). On Neon this is the "-pooler" host.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.REGION.aws.neon.tech/peptides?sslmode=require"
# Direct/unpooled connection — used by `prisma migrate` + `prisma db seed`.
DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxxx.REGION.aws.neon.tech/peptides?sslmode=require"

# --- Auth.js (login) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me"
# Public URL of the app (e.g. https://your-app.vercel.app). Optional locally.
# AUTH_URL="http://localhost:3000"

# --- Photo storage (Vercel Blob) ---
# Auto-injected on Vercel. Locally, run: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Optional: override the seeded demo login (prisma/seed.ts) ---
# SEED_ACCOUNT_EMAIL="local@peptides.app"
# SEED_ACCOUNT_PASSWORD="peptides123"
